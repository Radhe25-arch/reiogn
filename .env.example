# ============================================================
#  REIOGN — Environment Variables
#  Copy this file to .env.local and fill in your values
# ============================================================

# ── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (PostgreSQL) ──────────────────────────────────
DATABASE_URL="postgresql://reiogn:reiogn_pass@localhost:5432/reiogn"

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── JWT Secrets (generate with: openssl rand -base64 32) ──
JWT_ACCESS_SECRET=your_access_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── AI Provider ────────────────────────────────────────────
AI_PROVIDER=anthropic          # or: openai
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...          # optional if using anthropic

# ── Razorpay (Payments) ────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
RAZORPAY_PLAN_STARTER=plan_...
RAZORPAY_PLAN_PRO=plan_...
RAZORPAY_PLAN_ELITE=plan_...

# ── OAuth (all optional — leave blank to disable) ─────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Public OAuth IDs (used client-side for redirect URLs)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GITHUB_CLIENT_ID=
NEXT_PUBLIC_DISCORD_CLIENT_ID=

# ── Email (SMTP) ───────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
SMTP_FROM="REIOGN <noreply@reiogn.com>"
